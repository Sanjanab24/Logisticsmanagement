<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/dark_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Shipping Rates"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/dark_text_primary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Standard zone-based pricing"
        android:textColor="@color/dark_text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="28dp" />

    <ProgressBar
        android:id="@+id/ratesProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:indeterminateTint="@color/accent_red"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/ratesContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/dark_text_primary"
            android:textSize="14sp"
            android:lineSpacingExtra="6dp"
            android:text="Fetching rates..." />
    </LinearLayout>

</LinearLayout>
