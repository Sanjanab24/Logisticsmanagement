<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/dark_text_primary"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join SHIPWISE today"
            android:textSize="14sp"
            android:textColor="@color/dark_text_secondary"
            android:layout_marginBottom="32dp" />

        <!-- Avatar pick -->
        <FrameLayout
            android:id="@+id/avatarPickArea"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/bg_image_pick"
            android:layout_marginBottom="32dp"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/avatarPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/avatarPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📷"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Photo"
                    android:textSize="11sp"
                    android:textColor="@color/accent_red" />
            </LinearLayout>
        </FrameLayout>

        <!-- Full Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FULL NAME"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="@color/dark_text_secondary"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/name"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="John Doe"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/dark_text_primary"
            android:textColorHint="@color/dark_text_secondary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Email -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EMAIL"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="@color/dark_text_secondary"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/email"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="you@example.com"
            android:inputType="textEmailAddress"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/dark_text_primary"
            android:textColorHint="@color/dark_text_secondary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PASSWORD"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="@color/dark_text_secondary"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/password"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Min. 6 characters"
            android:inputType="textPassword"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/dark_text_primary"
            android:textColorHint="@color/dark_text_secondary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Confirm Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONFIRM PASSWORD"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="@color/dark_text_secondary"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/confirmPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Repeat password"
            android:inputType="textPassword"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/dark_text_primary"
            android:textColorHint="@color/dark_text_secondary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="28dp" />

        <Button
            android:id="@+id/registerBtn"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="CREATE ACCOUNT"
            android:textColor="@color/white"
            android:letterSpacing="0.08"
            android:textStyle="bold"
            android:background="@drawable/bg_button_red"
            android:layout_marginBottom="24dp" />

        <ProgressBar
            android:id="@+id/signupProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:indeterminateTint="@color/accent_red"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>