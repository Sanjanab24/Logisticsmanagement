<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Courier Performance"
            android:textColor="@color/dark_text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Rate cards and delivery SLA snapshot"
            android:textColor="@color/dark_text_secondary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical">

            <!-- Courier 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="12dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DELHIVERY"
                    android:textColor="@color/accent_red"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/courierOne"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SLA: 2.1 days\nSuccess: 96.7%\nCost: Rs 64/shipment"
                    android:textColor="@color/dark_text_primary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="6dp" />
            </LinearLayout>

            <!-- Courier 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="12dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XPRESSBEES"
                    android:textColor="@color/accent_red"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/courierTwo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SLA: 2.8 days\nSuccess: 95.1%\nCost: Rs 58/shipment"
                    android:textColor="@color/dark_text_primary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="6dp" />
            </LinearLayout>

            <!-- Courier 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BLUE DART"
                    android:textColor="@color/accent_red"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/courierThree"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SLA: 1.9 days\nSuccess: 97.8%\nCost: Rs 72/shipment"
                    android:textColor="@color/dark_text_primary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="6dp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
