<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Track Shipment"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/dark_text_primary"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter a product ID to track its status"
        android:textSize="14sp"
        android:textColor="@color/dark_text_secondary"
        android:layout_marginBottom="32dp" />

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_input_field"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="18sp"
            android:paddingStart="4dp"
            android:paddingEnd="8dp" />

        <EditText
            android:id="@+id/trackingInput"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="Product ID (1–20)"
            android:inputType="number"
            android:background="@null"
            android:textColor="@color/dark_text_primary"
            android:textColorHint="@color/dark_text_secondary"
            android:textSize="15sp" />
    </LinearLayout>

    <Button
        android:id="@+id/trackBtn"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="TRACK →"
        android:textColor="@color/white"
        android:letterSpacing="0.08"
        android:textStyle="bold"
        android:background="@drawable/bg_button_red"
        android:layout_marginBottom="24dp" />

    <ProgressBar
        android:id="@+id/trackProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:indeterminateTint="@color/accent_red"
        android:visibility="gone" />

    <!-- Result card -->
    <LinearLayout
        android:id="@+id/trackResultCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/dark_text_primary"
            android:lineSpacingExtra="6dp" />
    </LinearLayout>

</LinearLayout>